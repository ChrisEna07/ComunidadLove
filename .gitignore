# ==============================================================================
# ASSETS FILTERING (Keep only used/needed files)
# ==============================================================================

# Ignore all files under assets recursively
ComunidadLoveWeb/Assets/**/*

# Re-allow directory traversal for assets subfolders
!ComunidadLoveWeb/Assets/
!ComunidadLoveWeb/Assets/LOVE - KIDS/
!ComunidadLoveWeb/Assets/Love adora/
!ComunidadLoveWeb/Assets/MERCHANDISING/
!ComunidadLoveWeb/Assets/somos comunidad love/

# Keep only used assets in the root of Assets folder
!ComunidadLoveWeb/Assets/logo-color.png
!ComunidadLoveWeb/Assets/logo-blanco.png
!ComunidadLoveWeb/Assets/portada.jpg
!ComunidadLoveWeb/Assets/familia pastoral.jpg
!ComunidadLoveWeb/Assets/love_kids.png
!ComunidadLoveWeb/Assets/LoveWoman.png
